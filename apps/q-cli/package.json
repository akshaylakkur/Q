{
  "name": "@qode-agent/cli",
  "version": "0.3.0",
  "description": "Qode — Autonomous Coding Agent CLI",
  "type": "module",
  "bin": {
    "q-cli": "dist/main.mjs",
    "q": "dist/main.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:sync": "tsdown && cp dist/main.mjs \"${Q_HOME:-$HOME/.Q}/build/apps/q-cli/dist/main.mjs\" 2>/dev/null; cp dist/main.mjs.map \"${Q_HOME:-$HOME/.Q}/build/apps/q-cli/dist/main.mjs.map\" 2>/dev/null; echo '✓ synced to ~/.Q/build/'",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist dist-native"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@datastructures-js/priority-queue": "^6.3.5",
    "@earendil-works/pi-tui": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qode-agent/agent-core": "0.2.11",
    "@qode-agent/qprovs": "0.2.11",
    "@qode-agent/qmain": "0.2.11",
    "@qode-agent/runtime": "0.2.11",
    "@qode-agent/protocol": "0.2.11",
    "@qode-agent/qollab": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^8.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "diff": "^9.0.0",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.5.1",
    "p-limit": "^6.2.0",
    "pathe": "^2.0.0",
    "pino": "^9.6.0",
    "semver": "^7.7.0",
    "smol-toml": "^1.3.0",
    "uuid": "^11.1.0",
    "yauzl": "^3.3.2",
    "zod": "^4.3.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/semver": "^7.7.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
