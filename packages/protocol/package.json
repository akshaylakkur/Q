{
  "name": "@qode-agent/protocol",
  "version": "0.3.8",
  "description": "Qode — Shared local-to-remote wire protocol types",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
