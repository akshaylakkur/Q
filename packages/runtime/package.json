    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qode-agent/agent-core": "0.2.10",
    "@qode-agent/qprovs": "0.2.10",
    "@qode-agent/qmain": "0.2.10",
    "@qode-agent/telemetry": "0.2.10",
    "@qode-agent/oauth": "0.2.10",
    "zod": "^4.3.0",
    "smol-toml": "^1.3.0",
    "uuid": "^11.1.0",
    "pino": "^9.6.0",
    "pathe": "^2.0.0",
    "lru-cache": "^11.5.1",
    "p-limit": "^6.2.0",
    "ignore": "^7.0.5",
    "diff": "^9.0.0",
    "js-yaml": "^4.1.1",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
