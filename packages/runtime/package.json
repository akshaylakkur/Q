{
  "name": "@qode-agent/runtime",
  "version": "0.2.10",
  "description": "Qode — Shared app-level runtime (orchestrator, memory, mcp, skills, records, config)",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
