{
  "name": "@qode-agent/qprovs",
  "version": "0.2.10",
  "description": "Qode — LLM provider abstraction layer (Anthropic, OpenAI, Google, Ollama, etc.)",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
