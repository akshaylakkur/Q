{
  "name": "@qode-agent/agent-core",
  "version": "0.2.10",
  "description": "Qode — Core agent engine: agent loop, tool execution, sub-agents",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qode-agent/qprovs": "0.2.10",
    "@qode-agent/qmain": "0.2.10",
    "@qode-agent/telemetry": "0.2.10",
    "pathe": "^2.0.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
