{
  "name": "@qode-agent/q-remote",
  "version": "0.2.11",
  "description": "Qode — Headless remote agent daemon for cloud execution",
  "type": "module",
  "bin": {
    "q-remote": "dist/main.mjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:pack": "tsdown && npm pack --pack-destination ../../dist-packs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qode-agent/runtime": "0.2.11",
    "@qode-agent/agent-core": "0.2.11",
    "@qode-agent/qprovs": "0.2.11",
    "@qode-agent/qmain": "0.2.11",
    "@qode-agent/protocol": "0.2.11",
    "zod": "^4.3.0",
    "smol-toml": "^1.3.0",
    "uuid": "^11.1.0",
    "pino": "^9.6.0",
    "pathe": "^2.0.0",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
